# Dummy credentials for the test suite (loaded by pytest-dotenv via
# `env_files` in pyproject.toml). The values only need to be non-empty so
# asyncpraw/imgur clients can be constructed — real network calls are replayed
# from VCR cassettes, so these are never used against the live APIs.
REDDIT_CLIENT_ID="test_reddit_client_id"
REDDIT_CLIENT_SECRET="test_reddit_client_secret"
IMGUR_CLIENT_ID="test_imgur_client_id"
IMGUR_CLIENT_SECRET="test_imgur_client_secret"
